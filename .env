# ============================
# ToolBite Frontend Environment
# ============================

# Backend API Base URL (used by src/services/api.js)
VITE_API_URL=http://localhost:5000/api

# ============================
# AI Tool API Keys
# ============================

# OpenAI (used for Email Writer, Blog Generator, Paragraph Rewriter)
VITE_OPENAI_API_KEY=your_openai_api_key_here

# DeepAI (used for Background Remover, Image Enhancer)
VITE_DEEPAI_API_KEY=your_deepai_api_key_here

# ============================
# Backend (Node.js/Express)
# ============================
# NOTE: These are SERVER-SIDE only — do NOT prefix with VITE_
# If your backend is a separate project, put these in that project's .env

MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/toolbite?retryWrites=true&w=majority
JWT_SECRET=your_super_secret_jwt_key_here

# Cloudinary (for template image uploads)
CLOUDINARY_CLOUD_NAME=dz54atsyf
CLOUDINARY_API_KEY=322376592287147
